# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# TypeScript build artifacts in source directories
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Exception: Compact-compiled contract APIs (required for SDK build)
# These are generated by compactc and must be committed since CI can't run Compact compiler
!packages/contracts/src/managed/**/contract/*.js
!packages/contracts/src/managed/**/contract/*.js.map
!packages/contracts/src/managed/**/contract/*.d.ts

# Compact intermediate files (don't commit these - large binary files)
packages/contracts/src/managed/**/zkir/
packages/contracts/src/managed/**/keys/
packages/contracts/src/managed/**/compiler/

# Circuit assets for browser (generated by scripts/copy-circuits.sh)
apps/demo/public/circuits/
packages/wallet-extension/public/circuits/

# Windows artifacts
nul

# Test coverage
coverage/
.nyc_output/

# IDE and editors
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# Environment files
.env
.env.local
.env.*.local
.env.development
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Midnight/Compact
zkir/
compiler/
*.cjs.map

# Chrome extension build
packages/wallet-extension/dist/
*.crx
*.pem

# Electron build
release/
*.exe
*.msi
*.dmg
*.AppImage
*.deb
*.rpm

# Testing artifacts
*.local
.cache/

# Temporary files
*.bak
*.tmp
*.temp
tmp/
temp/

# Claude Code (local dev tools - not for GitHub)
.claude/
CLAUDE.md

# Handoff files (per user preference)
*HANDOFF*.md
HANDOFF_SUMMARY.md
subcoder/

# Review and prompt files
*REVIEW*.md
*PROMPT*.md

# Secrets (never commit)
*.key
*.pem
credentials.json
secrets.json

# Deployment artifacts
deployment-result.json
DEPLOYMENT_GUIDE.md

# LevelDB (private state storage)
midnight-cloak-deploy/
midnight-level-db/

# Test scripts with hardcoded seeds
scripts/test-deploy.ts
