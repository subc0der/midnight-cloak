# Midnight Cloak Demo Configuration
# Copy this file to .env.local and update values as needed

# API key for Midnight Cloak SDK (optional for demo)
VITE_MIDNIGHT_CLOAK_API_KEY=your-api-key

# Network: 'preprod' or 'mainnet'
VITE_MIDNIGHT_NETWORK=preprod

# Allow mock proofs for development (default: false)
# Set to 'true' ONLY for local development without proof server
# NEVER enable in production - it bypasses all ZK security guarantees
VITE_ALLOW_MOCK_PROOFS=true
