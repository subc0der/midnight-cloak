{
  "name": "demo",
  "version": "0.1.0",
  "description": "Demo application for Midnight Cloak SDK",
  "type": "module",
  "private": true,
  "scripts": {
    "copy:circuits": "bash ../../scripts/copy-circuits.sh",
    "dev": "vite",
    "prebuild": "npm run copy:circuits",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@midnight-cloak/core": "workspace:*",
    "@midnight-cloak/react": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-static-copy": "^3.2.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "midnight-cloak",
    "demo"
  ],
  "author": "subcoder",
  "license": "MIT"
}
