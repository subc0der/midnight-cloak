{
  "name": "midnight-cloak",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-knowledge identity verification infrastructure for Midnight",
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "ajv@<6.14.0": "6.14.0",
      "esbuild@<=0.24.2": "0.25.0"
    }
  },
  "keywords": [
    "midnight",
    "zero-knowledge",
    "identity",
    "verification",
    "zkp",
    "cardano",
    "web3"
  ],
  "author": "subcoder",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "demo": "tsx scripts/sdk-demo.ts",
    "build": "pnpm -r build",
    "build:contracts": "pnpm --filter @midnight-cloak/contracts build",
    "build:core": "pnpm --filter @midnight-cloak/core build",
    "build:react": "pnpm --filter @midnight-cloak/react build",
    "build:wallet": "pnpm --filter @midnight-cloak/wallet build",
    "dev": "pnpm --filter demo dev",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "git config core.hooksPath .hooks || true"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
