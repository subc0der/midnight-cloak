{
  "name": "@maskid/contracts",
  "version": "0.1.0",
  "description": "Compact smart contracts for MaskID on Midnight",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./age-verifier": {
      "import": "./managed/age-verifier/contract/index.cjs",
      "types": "./managed/age-verifier/contract/index.d.cts"
    },
    "./credential-registry": {
      "import": "./managed/credential-registry/contract/index.cjs",
      "types": "./managed/credential-registry/contract/index.d.cts"
    }
  },
  "files": [
    "dist",
    "src/*.compact",
    "managed"
  ],
  "scripts": {
    "compile": "compactc src/credential-registry.compact && compactc src/age-verifier.compact",
    "compile:check": "which compactc && pnpm compile || echo 'Compact compiler not installed - skipping compilation'",
    "build": "tsc",
    "build:full": "pnpm compile && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist zkir compiler",
    "deploy:testnet": "node --loader ts-node/esm src/deploy.ts"
  },
  "dependencies": {
    "@midnight-ntwrk/compact-runtime": "^0.9.0",
    "@midnight-ntwrk/ledger": "^4.0.0",
    "@midnight-ntwrk/midnight-js-contracts": "2.0.2",
    "@midnight-ntwrk/midnight-js-http-client-proof-provider": "2.0.2",
    "@midnight-ntwrk/midnight-js-indexer-public-data-provider": "2.0.2",
    "@midnight-ntwrk/midnight-js-level-private-state-provider": "2.0.2",
    "@midnight-ntwrk/midnight-js-node-zk-config-provider": "2.0.2",
    "@midnight-ntwrk/midnight-js-types": "2.0.2",
    "@midnight-ntwrk/wallet": "5.0.0",
    "@midnight-ntwrk/wallet-api": "5.0.0",
    "@midnight-ntwrk/zswap": "^4.0.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "maskid",
    "compact",
    "midnight",
    "smart-contracts",
    "zero-knowledge"
  ],
  "author": "subcoder",
  "license": "MIT"
}
