{
  "name": "@maskid/wallet-extension",
  "version": "0.1.0",
  "description": "MaskID Chrome extension wallet for credential management",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@maskid/core": "workspace:*",
    "@maskid/wallet": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "maskid",
    "chrome-extension",
    "wallet",
    "credentials"
  ],
  "author": "subcoder",
  "license": "MIT"
}
