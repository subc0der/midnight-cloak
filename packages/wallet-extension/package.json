{
  "name": "@midnight-cloak/wallet-extension",
  "version": "0.1.0",
  "description": "Midnight Cloak Chrome extension wallet for credential management",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@midnight-cloak/core": "workspace:*",
    "@midnight-cloak/wallet": "workspace:*",
    "hash-wasm": "^4.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.28",
    "@types/chrome": "^0.0.287",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "midnight-cloak",
    "chrome-extension",
    "wallet",
    "credentials"
  ],
  "author": "subcoder",
  "license": "Apache-2.0"
}
